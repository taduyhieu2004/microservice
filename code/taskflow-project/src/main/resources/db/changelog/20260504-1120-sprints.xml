<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-sprints-table" author="taskflow">
        <createTable tableName="sprints">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="goal" type="text"/>
            <column name="start_date" type="bigint"/>
            <column name="end_date" type="bigint"/>
            <column name="status" type="varchar(20)" defaultValue="PLANNING">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(255)"/>
            <column name="created_at" type="bigint"/>
            <column name="last_updated_by" type="varchar(255)"/>
            <column name="last_updated_at" type="bigint"/>
            <column name="deleted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="sprints" indexName="idx_sprints_project">
            <column name="project_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
