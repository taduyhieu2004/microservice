<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create-projects-table" author="taskflow">
        <createTable tableName="projects">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="key" type="varchar(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="type" type="varchar(20)" defaultValue="SOFTWARE">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(255)"/>
            <column name="created_at" type="bigint"/>
            <column name="last_updated_by" type="varchar(255)"/>
            <column name="last_updated_at" type="bigint"/>
            <column name="deleted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="projects" indexName="idx_projects_key">
            <column name="key"/>
        </createIndex>
        <createIndex tableName="projects" indexName="idx_projects_owner">
            <column name="owner_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
