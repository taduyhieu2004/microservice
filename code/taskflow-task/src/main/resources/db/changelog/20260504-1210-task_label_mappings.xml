<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="create-task_label_mappings-table" author="taskflow">
        <createTable tableName="task_label_mappings">
            <column name="task_id" type="bigint"><constraints nullable="false"/></column>
            <column name="label_id" type="bigint"><constraints nullable="false"/></column>
        </createTable>
        <addPrimaryKey tableName="task_label_mappings" columnNames="task_id,label_id"
                       constraintName="pk_task_label_mappings"/>
    </changeSet>
</databaseChangeLog>
